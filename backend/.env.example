# ─────────────────────────────────────────
#  FamTrack — Environment Variables
#  Copy this to .env and fill in values
# ─────────────────────────────────────────

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/famtrack?retryWrites=true&w=majority

# JWT secret (generate: openssl rand -base64 64)
JWT_SECRET=your_very_long_random_jwt_secret_here

# Client origin for CORS
CLIENT_ORIGIN=http://localhost:3000

# Twilio (for OTP SMS)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1XXXXXXXXXX

# Firebase Admin SDK (for push notifications)
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# Redis (for caching live locations)
REDIS_URL=redis://localhost:6379

# Google Maps API (for reverse geocoding)
GOOGLE_MAPS_KEY=AIza...
